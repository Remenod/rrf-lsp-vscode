{
  "name": "rrf-lsp-vscode",
  "displayName": "RRF G-Code Support",
  "description": "G-code Duet3D RRF Language Server",
  "author": "remenod",
  "license": "GPL-3.0-only",
  "version": "0.2.0",
  "publisher": "remenod",
  "categories": [
    "Programming Languages"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Remenod/rrf-lsp-vscode"
  },
  "activationEvents": [
    "onLanguage:rrf-gcode",
    "onLanguage:gcode"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rrf-gcode",
        "aliases": [
          "RRF GCode",
          "RepRapFirmware"
        ],
        "extensions": [
          ".gcode",
          ".g",
          ".gc",
          ".gco"
        ]
      }
    ],
    "configuration": {
      "title": "RRF G-Code Support",
      "properties": {
        "rrfgcode.activateOnGenericGcode": {
          "type": "boolean",
          "default": true,
          "description": "Enable LSP for generic non RRF gcode files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.0.0"
  }
}