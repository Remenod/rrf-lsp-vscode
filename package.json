{
  "name": "rrf-lsp-vscode",
  "displayName": "RepRapFirmware G-Code LSP",
  "description": "Language support, hover documentation and more for RepRapFirmware (Duet3D) G-code files.",
  "author": "remenod",
  "license": "GPL-3.0-only",
  "version": "1.4.0",
  "publisher": "remenod",
  "icon": "icon.png",
  "categories": [
    "Programming Languages"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Remenod/rrf-lsp-vscode"
  },
  "keywords": [
    "gcode",
    "reprapfirmware",
    "duet3d",
    "3d-printing",
    "cnc"
  ],
  "activationEvents": [
    "onLanguage:rrf-gcode",
    "onLanguage:gcode"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rrf-gcode",
        "aliases": [
          "RRF GCode",
          "RepRapFirmware"
        ],
        "extensions": [
          ".gcode",
          ".g",
          ".gc",
          ".gco"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "RRF G-Code Support",
      "properties": {
        "rrfgcode.activateOnGenericGcode": {
          "type": "boolean",
          "default": true,
          "description": "Enable LSP for generic non RRF gcode files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.25.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@duet3d/objectmodel": "^3.6.2",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  }
}